<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #FFFFFF;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.studentmanager.studentmanagementgui.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="PUP Student Management Portal" textFill="#800000">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>

        <Button text="+ Register New Student" onAction="#onOpenRegistrationClick" style="-fx-background-color: #FFDF00; -fx-text-fill: #800000; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Sign Out" onAction="#onSignOutClick" style="-fx-background-color: #FFFFFF; -fx-text-fill: #800000; -fx-border-color: #800000; -fx-border-radius: 3px; -fx-cursor: hand;"/>    </HBox>

    <Label fx:id="statusLabel" text="System: Ready" textFill="grey"/>

    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #800000; -fx-border-width: 1px;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="Student ID" />
            <TableColumn fx:id="colName" text="Name" />
            <TableColumn fx:id="colProgram" text="Program" />
            <TableColumn fx:id="colYear" text="Year Level" />
        </columns>
    </TableView>

    <Button text="Refresh Cloud Data" onAction="#onRefreshClick" style="-fx-background-color: #800000; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-cursor: hand;"/>

</VBox>